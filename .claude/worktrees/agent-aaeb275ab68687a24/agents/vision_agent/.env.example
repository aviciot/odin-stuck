# Google Maps Platform — used for Geocoding and Street View Static API
# Get your key at: https://console.cloud.google.com/apis/credentials
# Enable: Geocoding API + Street View Static API
GOOGLE_MAPS_API_KEY=

# fal.ai — used for FLUX.1 Kontext Pro image generation
# Get your key at: https://fal.ai/dashboard/keys
FAL_API_KEY=

# Anthropic — used only for natural-language input parsing (claude-haiku, cheap)
# Get your key at: https://console.anthropic.com/settings/api-keys
# Optional: if omitted, only structured JSON input is accepted
ANTHROPIC_API_KEY=

# Server config
PORT=9100
AGENT_VERSION=1.0.0
